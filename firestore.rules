rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsTask(data) {
      return signedIn() && data.userId == request.auth.uid;
    }

    function isValidTask(data) {
      return data.keys().hasOnly([
        'title',
        'description',
        'status',
        'priority',
        'startDate',
        'startTime',
        'dueDate',
        'dueTime',
        'createdAt',
        'completedAt',
        'userId'
      ])
      && data.keys().hasAll([
        'title',
        'description',
        'status',
        'priority',
        'dueDate',
        'createdAt',
        'completedAt',
        'userId'
      ])
      && data.title is string
      && data.description is string
      && data.status in ['todo', 'in-progress', 'completed']
      && data.priority in ['low', 'medium', 'high']
      && (!data.keys().hasAny(['startDate']) || data.startDate is string)
      && (!data.keys().hasAny(['startTime']) || data.startTime is string)
      && data.dueDate is string
      && (!data.keys().hasAny(['dueTime']) || data.dueTime is string)
      && data.createdAt is timestamp
      && (data.completedAt == null || data.completedAt is timestamp)
      && data.userId is string;
    }

    function ownsUserStats(userId, data) {
      return signedIn()
        && userId == request.auth.uid
        && data.userId == request.auth.uid;
    }

    function isValidUserStats(data) {
      return data.keys().hasOnly([
        'userId',
        'currentStreak',
        'longestStreak',
        'lastLoginDate',
        'updatedAt'
      ])
      && data.keys().hasAll([
        'userId',
        'currentStreak',
        'longestStreak',
        'lastLoginDate',
        'updatedAt'
      ])
      && data.userId is string
      && data.currentStreak is int
      && data.currentStreak >= 1
      && data.longestStreak is int
      && data.longestStreak >= data.currentStreak
      && data.lastLoginDate is string
      && data.updatedAt is timestamp;
    }

    match /tasks/{taskId} {
      allow read: if ownsTask(resource.data);
      allow create: if ownsTask(request.resource.data) && isValidTask(request.resource.data);
      allow update: if ownsTask(resource.data)
        && ownsTask(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && isValidTask(request.resource.data);
      allow delete: if ownsTask(resource.data);
    }

    match /userStats/{userId} {
      allow read: if signedIn() && userId == request.auth.uid;
      allow create, update: if ownsUserStats(userId, request.resource.data)
        && isValidUserStats(request.resource.data);
    }
  }
}
